  "keywords": ["obsidian", "obsidian-plugin", "chat", "capture", "quick-note"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.0",
    "typescript": "^5.0.0"
  }
}
