{
  "name": "obsidian-chat-flow",
  "version": "1.0.0",
  "description": "Chat-like rapid capture for Obsidian. Append timestamped messages to Chat.md, move to notes, voice recording.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
